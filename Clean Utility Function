// Debounce function (used in search bars, APIs, etc.)
function debounce(fn, delay = 300) {
  let timer;
  return (...args) => {
    clearTimeout(timer);
    timer = setTimeout(() => fn.apply(this, args), delay);
  };
}

// Example usage
const handleSearch = debounce((query) => {
  console.log("Searching for:", query);
}, 500);
